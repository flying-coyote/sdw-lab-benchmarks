    "tpch_q21": {
      "sql": "\nSELECT s_name, count(*) AS numwait\nFROM iceberg.tpch.supplier\nJOIN iceberg.tpch.lineitem l1 ON s_suppkey = l1.l_suppkey\nJOIN iceberg.tpch.orders ON o_orderkey = l1.l_orderkey\nJOIN iceberg.tpch.nation ON s_nationkey = n_nationkey\nWHERE o_orderstatus = 'F'\n  AND l1.l_receiptdate > l1.l_commitdate\n  AND EXISTS (\n    SELECT 1 FROM iceberg.tpch.lineitem l2\n    WHERE l2.l_orderkey = l1.l_orderkey AND l2.l_suppkey <> l1.l_suppkey\n  )\n  AND NOT EXISTS (\n    SELECT 1 FROM iceberg.tpch.lineitem l3\n    WHERE l3.l_orderkey = l1.l_orderkey AND l3.l_suppkey <> l1.l_suppkey\n      AND l3.l_receiptdate > l3.l_commitdate\n  )\n  AND n_name = 'SAUDI ARABIA'\nGROUP BY s_name\nORDER BY numwait DESC, s_name\nLIMIT 100\n",
