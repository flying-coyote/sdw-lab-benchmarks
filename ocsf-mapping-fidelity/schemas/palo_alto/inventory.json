    {"field": "flags", "type": "integer(bitfield)", "detection_relevant": true, "note": "32-bit PA session-characteristics bitfield (NAT-applied, captive-portal, proxy, decrypted, pcap...) — NOT TCP flags"},
    {"field": "proto", "type": "string", "detection_relevant": true, "note": "IP protocol (tcp/udp/icmp/...)"},
    {"field": "action", "type": "string(enum)", "detection_relevant": true, "note": "allow / deny / drop / drop-icmp / reset-client / reset-server / reset-both / drop-all"},
    {"field": "bytes", "type": "integer", "detection_relevant": true, "note": "total bytes (sent+received)"},
