{
  "_comment": "Palo Alto Networks PAN-OS TRAFFIC log field inventory, scored against OCSF Network Activity (4001). The PAN-OS TRAFFIC log is a fixed-position comma-separated record; PANW documents ~117 real leaf fields (excluding FUTURE_USE placeholders). This inventory scores the CORE NGFW traffic-session record (83 fields) and deliberately EXCLUDES five license/platform-gated extension families, named here so the scope is transparent rather than a convenient subset (see PROVENANCE.md for the rule and the per-family counts): SD-WAN (7), 5G/SCTP mobile-network inspection (8), CN-Series/Kubernetes container (5), GlobalProtect host-info (2), AI-security (2), plus Panorama device-group hierarchy (4), the HA/processing-internal fields, and the eight fields PANW labels 'Internal use only' (TCP RTT / out-of-sequence / retransmit / zero-window). The scored set is the session record a standard NGFW deployment emits. Leaf fields only; the 32-bit 'flags' and 'actionflags' bitfields are each one field (their bits are not separate schema fields). Field names are PANW's documented syslog field identifiers. Transcribed from the PAN-OS Administrator's Guide Traffic Log Fields reference; corroborated against Elastic Filebeat panw and Google SecOps. See PROVENANCE.md.",
  "source": "palo_alto",
  "source_schema": "PAN-OS TRAFFIC log (Syslog Field Descriptions, PAN-OS 11.0)",
  "scored_against_class": "network_activity (4001)",
  "fields": [
    {"field": "receive_time", "type": "timestamp", "detection_relevant": false, "note": "log receipt time at the management plane"},
    {"field": "serial", "type": "string", "detection_relevant": false, "note": "firewall serial number (reporting appliance)"},
    {"field": "type", "type": "string", "detection_relevant": false, "note": "log type, here TRAFFIC"},
    {"field": "subtype", "type": "string(enum)", "detection_relevant": true, "note": "traffic subtype: start / end / drop / deny"},
    {"field": "time_generated", "type": "timestamp", "detection_relevant": false, "note": "dataplane log generation time (event time)"},
    {"field": "src", "type": "ip", "detection_relevant": true, "note": "original (pre-NAT) source IP"},
    {"field": "dst", "type": "ip", "detection_relevant": true, "note": "original (pre-NAT) destination IP"},
    {"field": "natsrc", "type": "ip", "detection_relevant": true, "note": "post-NAT source IP"},
    {"field": "natdst", "type": "ip", "detection_relevant": true, "note": "post-NAT destination IP"},
    {"field": "rule", "type": "string", "detection_relevant": true, "note": "name of the matched security rule"},
    {"field": "srcuser", "type": "string", "detection_relevant": true, "note": "User-ID resolved source user"},
    {"field": "dstuser", "type": "string", "detection_relevant": true, "note": "User-ID resolved destination user"},
    {"field": "app", "type": "string", "detection_relevant": true, "note": "App-ID application name"},
    {"field": "vsys", "type": "string", "detection_relevant": false, "note": "virtual system id the session belongs to"},
