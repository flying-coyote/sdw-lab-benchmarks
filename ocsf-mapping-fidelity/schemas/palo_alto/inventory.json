    {"field": "logset", "type": "string", "detection_relevant": false, "note": "log forwarding profile applied"},
    {"field": "sessionid", "type": "string", "detection_relevant": true, "note": "firewall internal session id"},
    {"field": "repeatcnt", "type": "integer", "detection_relevant": false, "note": "count of sessions with same 5-tuple within 5s"},
    {"field": "sport", "type": "integer", "detection_relevant": true, "note": "source port"},
    {"field": "dport", "type": "integer", "detection_relevant": true, "note": "destination port"},
    {"field": "natsport", "type": "integer", "detection_relevant": true, "note": "post-NAT source port"},
