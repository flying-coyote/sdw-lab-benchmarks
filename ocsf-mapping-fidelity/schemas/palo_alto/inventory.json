    {"field": "src_host", "type": "string", "detection_relevant": true, "note": "Device-ID source hostname"},
    {"field": "src_mac", "type": "mac", "detection_relevant": true, "note": "Device-ID source MAC address"},
    {"field": "dst_category", "type": "string", "detection_relevant": true, "note": "Device-ID destination device category (rarely populated)"},
    {"field": "dst_profile", "type": "string", "detection_relevant": true, "note": "Device-ID destination device profile (rarely populated)"},
    {"field": "dst_model", "type": "string", "detection_relevant": true, "note": "Device-ID destination device model (rarely populated)"},
    {"field": "dst_vendor", "type": "string", "detection_relevant": true, "note": "Device-ID destination device vendor (rarely populated)"},
