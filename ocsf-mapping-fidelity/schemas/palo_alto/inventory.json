    {"field": "dst_host", "type": "string", "detection_relevant": true, "note": "Device-ID destination hostname (rarely populated)"},
    {"field": "dst_mac", "type": "mac", "detection_relevant": true, "note": "Device-ID destination MAC address (rarely populated)"},
    {"field": "src_edl", "type": "string", "detection_relevant": true, "note": "name of the source-IP External Dynamic List matched"},
